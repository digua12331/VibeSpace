{
  "$schema": "./permission-catalog.schema.json",
  "version": 1,
  "claude": {
    "presets": [
      {
        "id": "clear",
        "label": "🧹 清空",
        "description": "所有目录条目置为关闭，自定义条目不动。",
        "selections": {}
      },
      {
        "id": "readonly",
        "label": "🔒 只读",
        "description": "允许 Read/Glob/Grep/TodoWrite；拒绝 rm 等破坏性命令。",
        "selections": {
          "tool-read": "allow",
          "tool-glob": "allow",
          "tool-grep": "allow",
          "tool-todowrite": "allow",
          "git-status": "allow",
          "git-log": "allow",
          "git-diff": "allow",
          "git-branch": "allow",
          "git-show": "allow",
          "fs-ls": "allow",
          "fs-cat": "allow",
          "fs-head": "allow",
          "fs-tail": "allow",
          "fs-pwd": "allow",
          "fs-which": "allow",
          "fs-stat": "allow",
          "fs-tree": "allow",
          "fs-find": "allow",
          "fs-rm": "deny",
          "tool-write": "deny"
        }
      },
      {
        "id": "dev-conservative",
        "label": "💻 开发 (保守)",
        "description": "只读集合 + Edit/Write + pnpm/npm/node/npx + git 只读。破坏性 git 仍需确认。",
        "selections": {
          "tool-read": "allow",
          "tool-edit": "allow",
          "tool-write": "allow",
          "tool-multiedit": "allow",
          "tool-glob": "allow",
          "tool-grep": "allow",
          "tool-todowrite": "allow",
          "tool-task": "allow",
          "git-status": "allow",
          "git-log": "allow",
          "git-diff": "allow",
          "git-branch": "allow",
          "git-show": "allow",
          "git-add": "allow",
          "git-commit": "ask",
          "git-push": "ask",
          "git-reset": "ask",
          "git-checkout": "ask",
          "pkg-pnpm": "allow",
          "pkg-npm": "allow",
          "pkg-npx": "allow",
          "rt-node": "allow",
          "rt-tsx": "allow",
          "fs-ls": "allow",
          "fs-cat": "allow",
          "fs-head": "allow",
          "fs-tail": "allow",
          "fs-pwd": "allow",
          "fs-mkdir": "allow",
          "fs-cp": "allow",
          "fs-mv": "allow",
          "fs-find": "allow",
          "fs-which": "allow",
          "fs-stat": "allow",
          "fs-tree": "allow",
          "fs-rm": "ask"
        }
      },
      {
        "id": "dev-full",
        "label": "🛠 开发 (完整)",
        "description": "上一档 + 容器/curl/webfetch 常见域 + 破坏性 git 放行。",
        "selections": {
          "tool-read": "allow",
          "tool-edit": "allow",
          "tool-write": "allow",
          "tool-multiedit": "allow",
          "tool-glob": "allow",
          "tool-grep": "allow",
          "tool-todowrite": "allow",
          "tool-task": "allow",
          "tool-websearch": "allow",
          "tool-bashoutput": "allow",
          "git-status": "allow",
          "git-log": "allow",
          "git-diff": "allow",
          "git-branch": "allow",
          "git-show": "allow",
          "git-add": "allow",
          "git-commit": "allow",
          "git-push": "allow",
          "git-pull": "allow",
          "git-fetch": "allow",
          "git-stash": "allow",
          "git-reset": "ask",
          "git-checkout": "allow",
          "git-merge": "allow",
          "git-rebase": "ask",
          "git-tag": "allow",
          "pkg-pnpm": "allow",
          "pkg-npm": "allow",
          "pkg-yarn": "allow",
          "pkg-npx": "allow",
          "pkg-bun": "allow",
          "rt-node": "allow",
          "rt-tsx": "allow",
          "rt-tsnode": "allow",
          "rt-python": "allow",
          "rt-pip": "allow",
          "rt-uv": "allow",
          "fs-ls": "allow",
          "fs-cat": "allow",
          "fs-head": "allow",
          "fs-tail": "allow",
          "fs-pwd": "allow",
          "fs-mkdir": "allow",
          "fs-cp": "allow",
          "fs-mv": "allow",
          "fs-find": "allow",
          "fs-which": "allow",
          "fs-stat": "allow",
          "fs-du": "allow",
          "fs-tree": "allow",
          "fs-wc": "allow",
          "fs-rm": "ask",
          "net-curl": "allow",
          "net-wget": "allow",
          "proc-ps": "allow",
          "proc-tasklist": "allow",
          "b-make": "allow",
          "b-cargo": "allow",
          "b-go": "allow",
          "c-docker": "allow",
          "c-compose": "allow",
          "web-github": "allow",
          "web-ghraw": "allow",
          "web-npm": "allow",
          "web-pypi": "allow",
          "web-anthropic": "allow",
          "web-so": "allow",
          "web-gitlab": "allow"
        }
      },
      {
        "id": "yolo",
        "label": "⚡ 全权 (危险)",
        "description": "所有目录条目 allow；慎用。",
        "applyAllAllow": true,
        "selections": {}
      }
    ],
    "groups": [
      {
        "id": "tools",
        "label": "整工具",
        "description": "整个工具级别的 allow / ask / deny。细粒度模式请用下方分组。",
        "items": [
          { "id": "tool-bash",          "label": "Bash (任意命令)",          "value": "Bash" },
          { "id": "tool-read",          "label": "Read",                     "value": "Read" },
          { "id": "tool-edit",          "label": "Edit",                     "value": "Edit" },
          { "id": "tool-write",         "label": "Write",                    "value": "Write" },
          { "id": "tool-multiedit",     "label": "MultiEdit",                "value": "MultiEdit" },
          { "id": "tool-glob",          "label": "Glob",                     "value": "Glob" },
          { "id": "tool-grep",          "label": "Grep",                     "value": "Grep" },
          { "id": "tool-webfetch",      "label": "WebFetch (任意域)",         "value": "WebFetch" },
          { "id": "tool-websearch",     "label": "WebSearch",                "value": "WebSearch" },
          { "id": "tool-notebookedit",  "label": "NotebookEdit",             "value": "NotebookEdit" },
          { "id": "tool-task",          "label": "Task (子 agent)",          "value": "Task" },
          { "id": "tool-todowrite",     "label": "TodoWrite",                "value": "TodoWrite" },
          { "id": "tool-slashcommand",  "label": "SlashCommand",             "value": "SlashCommand" },
          { "id": "tool-bashoutput",    "label": "BashOutput",               "value": "BashOutput" },
          { "id": "tool-killshell",     "label": "KillShell",                "value": "KillShell" },
          { "id": "tool-exitplanmode",  "label": "ExitPlanMode",             "value": "ExitPlanMode" }
        ]
      },
      {
        "id": "git",
        "label": "Git 子命令",
        "items": [
          { "id": "git-status",  "label": "git status",  "value": "Bash(git status)" },
          { "id": "git-log",     "label": "git log",     "value": "Bash(git log:*)" },
          { "id": "git-diff",    "label": "git diff",    "value": "Bash(git diff:*)" },
          { "id": "git-branch",  "label": "git branch",  "value": "Bash(git branch:*)" },
          { "id": "git-show",    "label": "git show",    "value": "Bash(git show:*)" },
          { "id": "git-add",     "label": "git add",     "value": "Bash(git add:*)" },
          { "id": "git-commit",  "label": "git commit",  "value": "Bash(git commit:*)" },
          { "id": "git-push",    "label": "git push",    "value": "Bash(git push:*)" },
          { "id": "git-pull",    "label": "git pull",    "value": "Bash(git pull:*)" },
          { "id": "git-fetch",   "label": "git fetch",   "value": "Bash(git fetch:*)" },
          { "id": "git-stash",   "label": "git stash",   "value": "Bash(git stash:*)" },
          { "id": "git-reset",   "label": "git reset",   "value": "Bash(git reset:*)" },
          { "id": "git-checkout","label": "git checkout","value": "Bash(git checkout:*)" },
          { "id": "git-merge",   "label": "git merge",   "value": "Bash(git merge:*)" },
          { "id": "git-rebase",  "label": "git rebase",  "value": "Bash(git rebase:*)" },
          { "id": "git-tag",     "label": "git tag",     "value": "Bash(git tag:*)" }
        ]
