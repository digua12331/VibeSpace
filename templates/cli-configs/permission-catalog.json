          { "id": "fs-head",   "label": "head",   "value": "Bash(head:*)" },
          { "id": "fs-tail",   "label": "tail",   "value": "Bash(tail:*)" },
          { "id": "fs-pwd",    "label": "pwd",    "value": "Bash(pwd)" },
          { "id": "fs-mkdir",  "label": "mkdir",  "value": "Bash(mkdir:*)" },
          { "id": "fs-rm",     "label": "rm",     "value": "Bash(rm:*)" },
          { "id": "fs-cp",     "label": "cp",     "value": "Bash(cp:*)" },
          { "id": "fs-mv",     "label": "mv",     "value": "Bash(mv:*)" },
          { "id": "fs-find",   "label": "find",   "value": "Bash(find:*)" },
          { "id": "fs-which",  "label": "which",  "value": "Bash(which:*)" },
          { "id": "fs-stat",   "label": "stat",   "value": "Bash(stat:*)" },
          { "id": "fs-du",     "label": "du",     "value": "Bash(du:*)" },
          { "id": "fs-tree",   "label": "tree",   "value": "Bash(tree:*)" },
          { "id": "fs-wc",     "label": "wc",     "value": "Bash(wc:*)" }
        ]
      },
      {
        "id": "net-shell",
        "label": "网络 Shell",
        "items": [
          { "id": "net-curl", "label": "curl *", "value": "Bash(curl:*)" },
          { "id": "net-wget", "label": "wget *", "value": "Bash(wget:*)" },
          { "id": "net-ping", "label": "ping *", "value": "Bash(ping:*)" }
        ]
      },
      {
