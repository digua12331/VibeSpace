        ]
      },
      {
        "id": "build",
        "label": "构建",
        "items": [
          { "id": "b-make",   "label": "make *",   "value": "Bash(make:*)" },
          { "id": "b-cargo",  "label": "cargo *",  "value": "Bash(cargo:*)" },
          { "id": "b-go",     "label": "go *",     "value": "Bash(go:*)" },
          { "id": "b-cmake",  "label": "cmake *",  "value": "Bash(cmake:*)" },
          { "id": "b-mvn",    "label": "mvn *",    "value": "Bash(mvn:*)" },
          { "id": "b-gradle", "label": "gradle *", "value": "Bash(gradle:*)" }
        ]
      },
      {
        "id": "container",
        "label": "容器",
        "items": [
          { "id": "c-docker",  "label": "docker *",          "value": "Bash(docker:*)" },
          { "id": "c-compose", "label": "docker-compose *",  "value": "Bash(docker-compose:*)" },
          { "id": "c-kubectl", "label": "kubectl *",         "value": "Bash(kubectl:*)" }
        ]
      },
      {
        "id": "sys-win",
        "label": "Windows 系统",
        "items": [
          { "id": "w-powershell",  "label": "powershell *", "value": "Bash(powershell:*)" },
          { "id": "w-wmic",        "label": "wmic *",       "value": "Bash(wmic:*)" },
          { "id": "w-systeminfo",  "label": "systeminfo",   "value": "Bash(systeminfo)" },
          { "id": "w-netstat",     "label": "netstat",      "value": "Bash(netstat:*)" },
          { "id": "w-ipconfig",    "label": "ipconfig",     "value": "Bash(ipconfig:*)" }
        ]
      },
      {
        "id": "sys-unix",
        "label": "Unix 系统",
        "items": [
          { "id": "u-uname",  "label": "uname",  "value": "Bash(uname:*)" },
          { "id": "u-whoami", "label": "whoami", "value": "Bash(whoami)" },
          { "id": "u-env",    "label": "env",    "value": "Bash(env)" },
          { "id": "u-df",     "label": "df",     "value": "Bash(df:*)" },
          { "id": "u-free",   "label": "free",   "value": "Bash(free:*)" },
          { "id": "u-top",    "label": "top",    "value": "Bash(top:*)" }
        ]
      },
      {
        "id": "web-domains",
        "label": "WebFetch 域白名单",
        "description": "按域名精确允许 WebFetch。勾选 deny 可阻止对应域。",
        "items": [
          { "id": "web-github",     "label": "github.com",              "value": "WebFetch(domain:github.com)" },
          { "id": "web-ghraw",      "label": "raw.githubusercontent.com","value": "WebFetch(domain:raw.githubusercontent.com)" },
          { "id": "web-npm",        "label": "npmjs.com",               "value": "WebFetch(domain:npmjs.com)" },
          { "id": "web-pypi",       "label": "pypi.org",                "value": "WebFetch(domain:pypi.org)" },
          { "id": "web-anthropic",  "label": "docs.anthropic.com",      "value": "WebFetch(domain:docs.anthropic.com)" },
          { "id": "web-so",         "label": "stackoverflow.com",       "value": "WebFetch(domain:stackoverflow.com)" },
          { "id": "web-gitlab",     "label": "gitlab.com",              "value": "WebFetch(domain:gitlab.com)" },
          { "id": "web-medium",     "label": "medium.com",              "value": "WebFetch(domain:medium.com)" },
          { "id": "web-devto",      "label": "dev.to",                  "value": "WebFetch(domain:dev.to)" }
        ]
      }
