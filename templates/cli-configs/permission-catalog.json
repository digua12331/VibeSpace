        "label": "进程",
        "items": [
          { "id": "proc-tasklist", "label": "tasklist (Win)", "value": "Bash(tasklist:*)" },
          { "id": "proc-taskkill", "label": "taskkill (Win)", "value": "Bash(taskkill:*)" },
