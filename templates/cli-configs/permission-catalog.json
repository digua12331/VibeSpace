      {
        "id": "pkg",
        "label": "包管理",
        "items": [
          { "id": "pkg-pnpm", "label": "pnpm *", "value": "Bash(pnpm:*)" },
          { "id": "pkg-npm",  "label": "npm *",  "value": "Bash(npm:*)" },
          { "id": "pkg-yarn", "label": "yarn *", "value": "Bash(yarn:*)" },
          { "id": "pkg-bun",  "label": "bun *",  "value": "Bash(bun:*)" },
          { "id": "pkg-npx",  "label": "npx *",  "value": "Bash(npx:*)" }
        ]
      },
      {
        "id": "runtime",
        "label": "运行时",
        "items": [
          { "id": "rt-node",   "label": "node *",   "value": "Bash(node:*)" },
