  },
  "codex": {
    "presets": [
      {
        "id": "readonly",
        "label": "🔒 只读",
        "description": "沙盒只读，任何改动都需确认。",
        "values": {
          "approval_policy": "on-request",
          "sandbox_mode": "read-only"
        }
      },
      {
        "id": "workspace",
        "label": "💻 工作区可写 (无网)",
        "description": "允许改动项目目录，网络关闭。",
        "values": {
          "approval_policy": "on-request",
          "sandbox_mode": "workspace-write",
          "sandbox_workspace_write.network_access": false
        }
      },
      {
        "id": "workspace-net",
        "label": "🌐 工作区可写 + 网络",
        "description": "允许改动项目目录，允许网络。",
        "values": {
          "approval_policy": "on-request",
          "sandbox_mode": "workspace-write",
          "sandbox_workspace_write.network_access": true
        }
      },
      {
        "id": "yolo",
        "label": "⚡ 不受限 (危险)",
        "description": "沙盒完全关闭，永不询问。慎用。",
        "values": {
          "approval_policy": "never",
          "sandbox_mode": "danger-full-access"
        }
      }
    ],
    "fields": [
      {
        "id": "approval_policy",
        "label": "审批策略 (approval_policy)",
        "kind": "single",
        "path": "approval_policy",
        "options": [
          { "value": "never",       "label": "never — 永不询问" },
          { "value": "on-failure",  "label": "on-failure — 失败时询问" },
          { "value": "on-request",  "label": "on-request — 按需询问 (默认推荐)" },
          { "value": "untrusted",   "label": "untrusted — 所有危险操作都询问" }
        ]
      },
      {
        "id": "sandbox_mode",
        "label": "沙盒模式 (sandbox_mode)",
        "kind": "single",
        "path": "sandbox_mode",
        "options": [
          { "value": "read-only",            "label": "read-only" },
          { "value": "workspace-write",      "label": "workspace-write" },
          { "value": "danger-full-access",   "label": "danger-full-access (不受限)" }
        ]
      },
      {
        "id": "ws_network",
        "label": "workspace-write: 允许网络访问",
        "kind": "bool",
        "path": "sandbox_workspace_write.network_access"
      },
      {
        "id": "ws_excl_tmp_env",
        "label": "workspace-write: 排除 $TMPDIR 可写",
        "kind": "bool",
        "path": "sandbox_workspace_write.exclude_tmpdir_env_var"
      },
      {
        "id": "ws_excl_slash_tmp",
        "label": "workspace-write: 排除 /tmp 可写",
        "kind": "bool",
        "path": "sandbox_workspace_write.exclude_slash_tmp"
      },
      {
        "id": "ws_writable_roots",
        "label": "workspace-write: 额外可写目录 (writable_roots)",
        "kind": "stringList",
        "path": "sandbox_workspace_write.writable_roots",
        "placeholder": "一行一个绝对路径"
      },
      {
        "id": "hide_agent_reasoning",
        "label": "隐藏推理摘要 (hide_agent_reasoning)",
        "kind": "bool",
        "path": "hide_agent_reasoning"
      },
      {
        "id": "show_raw_agent_reasoning",
        "label": "显示原始推理 (show_raw_agent_reasoning)",
        "kind": "bool",
        "path": "show_raw_agent_reasoning"
      },
      {
        "id": "reasoning_effort",
        "label": "推理投入 (model_reasoning_effort)",
        "kind": "single",
        "path": "model_reasoning_effort",
        "options": [
          { "value": "minimal", "label": "minimal" },
          { "value": "low",     "label": "low" },
          { "value": "medium",  "label": "medium" },
          { "value": "high",    "label": "high" }
        ]
      },
      {
        "id": "reasoning_summary",
        "label": "推理摘要 (model_reasoning_summary)",
        "kind": "single",
        "path": "model_reasoning_summary",
        "options": [
          { "value": "auto",     "label": "auto" },
          { "value": "concise",  "label": "concise" },
          { "value": "detailed", "label": "detailed" },
          { "value": "none",     "label": "none" }
        ]
      },
      {
        "id": "verbosity",
        "label": "模型话痨程度 (model_verbosity)",
        "kind": "single",
        "path": "model_verbosity",
        "options": [
          { "value": "low",    "label": "low" },
          { "value": "medium", "label": "medium" },
          { "value": "high",   "label": "high" }
        ]
      }
    ]
  }
}
