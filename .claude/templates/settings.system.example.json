{
  "_doc": {
    "tier": "system (template)",
    "purpose": "拷到 ~/.claude/settings.json 当跨项目通用 entry 起点。覆盖工具族裸名 + 通用命令族 + deny 红线。hooks/plugins/env 按各人实际装的工具自行追加",
    "rules": "只放跨项目都用得到的；项目专属的进 <project>/.claude/settings.json；本机一次性的进 <project>/.claude/settings.local.json",
    "checklist": [
      "拷到 ~/.claude/settings.json（已有就 merge，不要整段覆盖）",
      "按需补 hooks / enabledPlugins / 个人 WebFetch 域名白名单",
      "deny 红线段按自己常用主分支名调整（develop / trunk 等）"
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "TodoWrite",
