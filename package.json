{
  "name": "vibespace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @aimon/server dev",
    "dev:server": "pnpm --filter @aimon/server dev",
    "dev:web": "pnpm --filter @aimon/web dev",
    "dev:all": "pnpm -r --parallel run dev",
    "dev:alt": "cross-env AIMON_PORT=9787 AIMON_WEB_PORT=9788 AIMON_SKIP_HOOK_INSTALL=1 AIMON_WEB_ORIGIN=http://127.0.0.1:9788,http://localhost:9788 AIMON_BACKEND_URL=http://127.0.0.1:9787 VITE_AIMON_BACKEND=http://127.0.0.1:9787 VITE_AIMON_INSTANCE_LABEL=开发 pnpm -r --parallel run dev",
    "build": "pnpm -r build",
    "build:stable": "cross-env VITE_AIMON_INSTANCE_LABEL=稳定 pnpm -r build",
    "start:stable": "concurrently \"pnpm --filter @aimon/server start\" \"pnpm --filter @aimon/web preview\"",
    "smoke:server": "node scripts/server-smoke.mjs",
    "smoke:web": "node scripts/web-smoke.mjs",
    "smoke:hooks": "node scripts/hooks-smoke.mjs",
    "smoke:codex": "node scripts/codex-smoke.mjs",
    "smoke:persistence": "node scripts/persistence-check.mjs",
    "smoke:refresh": "node scripts/refresh-smoke.mjs",
    "smoke:git": "node scripts/git-smoke.mjs"
  },
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@homebridge/node-pty-prebuilt-multiarch",
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3"
  }
}
